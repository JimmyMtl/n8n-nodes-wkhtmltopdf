# Copy to .env and adjust for the docker-compose test stack.

# n8n image tag to build on top of.
N8N_VERSION=2.26.0

# Timezone for the n8n container.
TZ=UTC

# Set to true to reinstall the node from /opt/code-temp on the next container
# start (do this after `pnpm build` to pick up code changes).
REINSTALL_WKHTMLTOPDF_NODE=false
