{
  "name": "@kash_maxing/n8n-nodes-html-to-pdf",
  "version": "1.0.1",
  "description": "n8n node for converting HTML to PDF using wkhtmltopdf",
  "keywords": [
    "n8n-community-node-package"
  ],
  "license": "MIT",
  "homepage": "https://github.com/diino/n8n-nodes-html-to-pdf",
  "author": {
    "name": "diino",
    "email": "diino@example.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/diino/n8n-nodes-html-to-pdf.git"
  },
  "main": "index.js",
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "format": "prettier nodes credentials --write",
    "lint": "eslint nodes/**/*.ts package.json",
    "lintfix": "eslint nodes/**/*.ts package.json --fix",
    "prepublishOnly": "npm run build && npm run lint -s"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [],
    "nodes": [
      "dist/nodes/HtmlToPdf/HtmlToPdf.node.js"
    ]
  },
  "devDependencies": {
    "@types/node": "^18.16.0",
    "@typescript-eslint/eslint-plugin": "^5.59.0",
    "@typescript-eslint/parser": "^5.59.0",
    "eslint": "^8.40.0",
    "eslint-plugin-n8n-nodes-base": "^1.11.0",
    "gulp": "^4.0.2",
    "n8n-workflow": "^1.82.0",
    "prettier": "^2.8.0",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "dependencies": {
    "wkhtmltopdf": "^0.4.0"
  }
}
