{
  "name": "n8n-nodes-wkhtmltopdf",
  "version": "1.0.0",
  "description": "n8n node for converting HTML to PDF using wkhtmltopdf",
  "keywords": [
    "n8n-community-node-package",
    "html-to-pdf",
    "html",
    "pdf",
    "conversion"
  ],
  "license": "MIT",
  "homepage": "https://github.com/JimmyMtl/n8n-nodes-wkhtmltopdf",
  "author": {
    "name": "diino",
    "email": "diino@example.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JimmyMtl/n8n-nodes-wkhtmltopdf.git"
  },
  "main": "index.js",
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "format": "prettier nodes credentials --write",
    "lint": "eslint nodes/**/*.ts package.json",
    "lintfix": "eslint nodes/**/*.ts package.json --fix",
    "prepublishOnly": "npm run build && npm run lint -s"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [],
    "nodes": [
      "dist/nodes/HtmlToPdf/HtmlToPdf.node.js"
    ]
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@typescript-eslint/eslint-plugin": "^8.47.0",
    "@typescript-eslint/parser": "^8.47.0 ",
    "eslint": "^8.57.1",
    "eslint-plugin-n8n-nodes-base": "^1.16.4",
    "gulp": "^5.0.1",
    "n8n-workflow": "^1.118.1",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "dependencies": {
    "wkhtmltopdf": "^0.4.0"
  }
}
